# ============================================================
# Logvale Devoluções — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione .env.local
# ============================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App (obrigatório)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webmania (fase 2 — deixar vazio em desenvolvimento inicial)
WEBMANIA_API_TOKEN=
WEBMANIA_CONSUMER_SECRET=
WEBMANIA_BASE_URL=https://api.webmaniabr.com

# Resend (fase 6 — deixar vazio em desenvolvimento inicial)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=notificacoes@logvale.com.br

# Node
NODE_ENV=development
