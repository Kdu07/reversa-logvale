# ============================================================
# Logvale Devoluções — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione .env.local
# ============================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App (obrigatório)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Conta super (opcional) — e-mails com acesso a todas as telas (admin + operador + cliente).
# Lista separada por vírgula. Apenas servidor (NÃO usar NEXT_PUBLIC_). A conta ainda
# precisa existir como profile 'manager' com este e-mail.
SUPER_ADMIN_EMAILS=

# Webmania — 4 credenciais OAuth do painel da conta.
# Reservadas para a integração FUTURA de consulta de NF/XML; atualmente NÃO são usadas pelo
# código (a NF é identificada por parsing local da chave de acesso, sem chamada externa).
WEBMANIA_CONSUMER_KEY=
WEBMANIA_CONSUMER_SECRET=
WEBMANIA_ACCESS_TOKEN=
WEBMANIA_ACCESS_TOKEN_SECRET=
WEBMANIA_BASE_URL=https://webmania.com.br/api

# Resend (fase 6 — deixar vazio em desenvolvimento inicial)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=notificacoes@logvale.com.br

# Sentry (fase 8 — deixar vazio para desabilitar em desenvolvimento)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Node
NODE_ENV=development
