# ============================================================
# Logvale Devoluções — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione .env.local
# ============================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App (obrigatório)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webmania — 4 credenciais OAuth do painel da conta (opcional: mock ativo quando ausentes)
WEBMANIA_CONSUMER_KEY=
WEBMANIA_CONSUMER_SECRET=
WEBMANIA_ACCESS_TOKEN=
WEBMANIA_ACCESS_TOKEN_SECRET=
WEBMANIA_BASE_URL=https://webmaniabr.com/api

# Resend (fase 6 — deixar vazio em desenvolvimento inicial)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=notificacoes@logvale.com.br

# Sentry (fase 8 — deixar vazio para desabilitar em desenvolvimento)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Node
NODE_ENV=development

# === AIOX Variables (added 2026-05-28) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
AIOX_VERSION=5.2.9

# AIOX_NOTE: The following variables already exist with different values:
# AIOX_SUGGESTED: SUPABASE_SERVICE_ROLE_KEY=

