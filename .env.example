# ============================================================
# Logvale Devoluções — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione .env.local
# ============================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App (obrigatório)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Conta super (opcional) — e-mails com acesso a todas as telas (admin + operador + cliente).
# Lista separada por vírgula. Apenas servidor (NÃO usar NEXT_PUBLIC_). A conta ainda
# precisa existir como profile 'manager' com este e-mail.
SUPER_ADMIN_EMAILS=

# NFEio — consulta de NF-e por chave de acesso (XML + DANFE) no fluxo do operador.
# NFEIO_ACCESS_KEY = API Key da empresa (enviada no header HTTP `Authorization`).
# Vazio = integração desligada: o recebimento ainda conclui (depositante vem do CNPJ da chave)
# e o XML/PDF ficam pendentes para o painel super-only de backfill.
NFEIO_ACCESS_KEY=
NFEIO_BASE_URL=https://nfe.api.nfe.io

# E-mail transacional via SMTP (Google Workspace) com OAuth2 / Service Account.
# A service account impersona GMAIL_OAUTH_USER via Domain-Wide Delegation — sem senha
# nem App Password (necessário em Workspace sem verificação em 2 etapas). Veja docs/SETUP.md.
# Vazio = envio desligado (link de ativação mostrado para envio manual).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465                                  # 465 = TLS implícito (recomendado p/ XOAUTH2)
MAIL_FROM=cadu@logvale.com.br
GMAIL_OAUTH_USER=cadu@logvale.com.br           # caixa que a service account impersona
GOOGLE_SA_CLIENT_ID=                           # "ID exclusivo" (numérico) da service account
# private_key do JSON da service account. Mantenha as quebras como \n literais entre aspas.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email da service account — usado pela Edge Function warning-email (Deno).
GOOGLE_SA_CLIENT_EMAIL=logvale-mailer@PROJETO.iam.gserviceaccount.com

# Sentry (fase 8 — deixar vazio para desabilitar em desenvolvimento)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Node
NODE_ENV=development
